    "sample:strict": "node draft-entries.mjs --session ~/.claude/projects/-Users-stephanemacmini/ --matter ./examples/test-matter-strict.yml --since 2026-05-15 --until 2026-05-17 --strict --out out/sample-draft-strict.md"
  },
